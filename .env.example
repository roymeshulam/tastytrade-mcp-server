# tastytrade-mcp-server configuration
#
# Preferred auth uses OAuth refresh-token credentials. A provided session token
# or username/password still works as a fallback for sandbox/dev workflows.
# Keep real credentials in your local environment or an ignored .env file.

TASTYTRADE_ENV=production
# TASTYTRADE_API_BASE_URL=https://api.cert.tastytrade.com

# Preferred:
REFRESH_TOKEN=your_refresh_token_here
CLIENT_SECRET=your_client_secret_here
ACCOUNT_NUMBER=your_account_number_here

# Fallback for local MCP usage when you already have a session token:
# TASTYTRADE_SESSION_TOKEN=

# Fallback used only when refresh-token credentials and TASTYTRADE_SESSION_TOKEN
# are not set:
# TASTYTRADE_USERNAME=
# TASTYTRADE_PASSWORD=

# MCP transport:
# - stdio: local clients launch this process and talk over stdin/stdout
# - streamable-http: long-running remote/server deployment
MCP_TRANSPORT=stdio
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
# MCP_STREAMABLE_HTTP_PATH=/mcp
# MCP_ALLOWED_HOSTS=127.0.0.1:8000,localhost:8000
# MCP_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
